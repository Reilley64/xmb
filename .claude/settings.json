{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import sys,json; d=json.load(sys.stdin); exit(1 if 'bun.lock' in d.get('file_path','') else 0)\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/reilley/Repositories/my-expo-app/.claude/hooks/biome-format.sh"
          },
          {
            "type": "command",
            "command": "bash /Users/reilley/Repositories/my-expo-app/.claude/hooks/tsc-check.sh"
          }
        ]
      }
    ]
  }
}
